# Copy this file to .env and fill real values

# Facebook / Meta
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_API_VERSION=v22.0
FACEBOOK_SUBSCRIBED_FIELDS=feed,messages

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=raw_events

# AI Service
Gemini:ApiKey=YOUR_API_KEY
